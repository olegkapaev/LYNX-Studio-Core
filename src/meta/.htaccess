# Rewrite engine configuration (Настройка движка перенаправлений)
RewriteEngine On

# Error pages custom paths inside folder (Кастомные пути страниц ошибок внутри папки)
ErrorDocument 403 /pages/errors/403.html
ErrorDocument 404 /pages/errors/404.html
ErrorDocument 500 /pages/errors/500.html
ErrorDocument 504 /pages/errors/504.html